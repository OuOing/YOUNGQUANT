# YoungQuant 环境变量配置
# 复制此文件为 .env 并填写实际值

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# JWT 签名密钥（必填，生产环境请使用随机字符串）
# 生成方法：openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-32-char-string

# PostgreSQL 密码（Docker 部署时使用）
POSTGRES_PASSWORD=change-this-to-a-strong-password

# 项目目录（本地开发时可不填，Docker 部署时自动设置）
# PROJECT_DIR=/app
